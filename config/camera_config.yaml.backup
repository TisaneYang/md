# 摄像头配置文件
# 定义路侧摄像头的位姿、内参和相互关系
# 配置与leaderboard_evaluator.py中的CARLA相机设置保持一致

cameras:
  # 前置摄像头：面向车辆方向
  - id: "front"
    name: "前置路侧摄像头"
    location:
      # 位置由车辆起点动态计算：起点 + 前进方向 * 50m
      # x, y, z 在运行时根据车辆spawn位置和路线方向计算
      x: 0.0      # 世界坐标系X位置（米）- 运行时更新
      y: 0.0      # 世界坐标系Y位置（米）- 运行时更新
      z: 5.0      # 世界坐标系Z位置（米，高度）- 固定在地面上方5米
    rotation:
      # 旋转角度动态计算以朝向车辆起点
      pitch: 0.0    # 俯仰角（度）- 运行时计算
      yaw: 0.0      # 航向角（度）- 运行时计算
      roll: 0.0     # 翻滚角（度）
    intrinsics:
      # 内参根据CARLA相机设置计算
      # image_size_x=800, image_size_y=600, fov=90
      # fx = fy = image_width / (2 * tan(fov/2))
      # fx = fy = 800 / (2 * tan(45°)) = 800 / 2 = 400
      fx: 400.0     # X方向焦距
      fy: 400.0     # Y方向焦距
      cx: 400.0     # 主点X坐标 (image_width / 2)
      cy: 300.0     # 主点Y坐标 (image_height / 2)
    image_size:
      width: 800    # 与CARLA设置一致
      height: 600   # 与CARLA设置一致
    fov: 90.0       # 视场角（度）

  # 后置摄像头：背向车辆方向
  - id: "rear"
    name: "后置路侧摄像头"
    location:
      # 与前置摄像头位置相同
      x: 0.0      # 世界坐标系X位置（米）- 运行时更新
      y: 0.0      # 世界坐标系Y位置（米）- 运行时更新
      z: 5.0      # 世界坐标系Z位置（米，高度）
    rotation:
      # 旋转角度为前置摄像头yaw + 180°，pitch取反
      pitch: 0.0    # 俯仰角（度）- 运行时计算（-front_pitch）
      yaw: 180.0    # 航向角（度）- 运行时计算（front_yaw + 180）
      roll: 0.0     # 翻滚角（度）
    intrinsics:
      fx: 400.0     # X方向焦距
      fy: 400.0     # Y方向焦距
      cx: 400.0     # 主点X坐标
      cy: 300.0     # 主点Y坐标
    image_size:
      width: 800
      height: 600
    fov: 90.0

# 摄像头之间的关系描述
camera_relationships:
  - cameras: ["front", "rear"]
    type: "back_to_back"
    description: "两个摄像头背靠背设置在同一位置，前置摄像头面向车辆起点，后置摄像头背向车辆"
    distance_from_vehicle: 50.0  # 距离车辆起点50米
    height_above_ground: 5.0     # 距离地面5米
